---
import '../styles/main.css';
import Bodega from '../../public/Bodega.png';
import Vina from '../../public/Vina.png';
import Wellu from '../../public/Wellu.png';import '../styles/main.css';
---

<div id="work-showcase">
  <div class="carousel">
    <div class="carousel-track">
      <div class="carousel-item"><a target="_blank" href="https://www.google.cl"><img src={Bodega.src} alt="Work 1" /></a></div>
      <div class="carousel-item"><img src={Wellu.src} alt="Work 2" /></div>
      <div class="carousel-item"><img src={Vina.src} alt="Work 3" /></div>
      <div class="carousel-item"><img src={Bodega.src} alt="Work 4" /></div>
      <div class="carousel-item"><img src={Wellu.src} alt="Work 5" /></div>
      <div class="carousel-item"><img src={Vina.src} alt="Work 6" /></div>
    </div>
    <button class="carousel-control prev" onclick="moveCarousel(-1)">&#10094;</button>
    <button class="carousel-control next" onclick="moveCarousel(1)">&#10095;</button>
  </div>
</div>

<script>
let currentIndex = 0;

function moveCarousel(direction: number) {
  const track = document.querySelector('.carousel-track');
  const items = document.querySelectorAll('.carousel-item');
  const totalItems = items.length;
  const itemsToShow = 3; // Number of items to show at a time

  currentIndex = (currentIndex + direction + totalItems) % totalItems;

  const offset = -currentIndex * (100 / itemsToShow);
  if (track) {
    (track as HTMLElement).style.transform = `translateX(${offset}%)`;
  }
}

// Show the first set of images on load
document.addEventListener('DOMContentLoaded', () => {
  moveCarousel(0);
});

document.querySelectorAll('.carousel-control').forEach((control) => {
  control.addEventListener('click', (event) => {
    const target = event.target;
    if (target && (target as Element).classList.contains('prev')) {
      moveCarousel(-1);
    } else if (target) {
      moveCarousel(1);
    }
  });
});
</script>
